<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".RmpApplication"
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="Resource Manager Pro"
        android:theme="@style/Theme.RmpMobile"
        android:usesCleartextTraffic="true">

        <!--
          usesCleartextTraffic=true is for local-dev (http://10.0.2.2:8080) only.
          Remove this and switch BASE_URL to https:// before shipping a release build.
        -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.RmpMobile">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!--
          Disables WorkManager's default on-demand initializer (an androidx.startup
          ContentProvider, which always runs before Application.onCreate()). Left enabled,
          it reads RmpApplication's Configuration.Provider before Hilt has injected
          workerFactory, silently falls back to the default WorkerFactory, and every
          @HiltWorker (SyncWorker) then fails with NoSuchMethodException trying to use a
          plain (Context, WorkerParameters) constructor it doesn't have (Cleanup
          Half-Sprint). Removing this forces WorkManager to initialize lazily on the first
          WorkManager.getInstance(context) call instead — which happens via
          RmpApplication's own syncScheduler field injection, safely after workerFactory
          is set (confirmed via the generated MembersInjector's field-injection order).
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Lets exported report PDFs (saved to app-scoped storage, no runtime
             permission needed) be shared/opened via a content:// Uri. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
